# Raqeem Control Center — environment variables (server-side only)
#
# Copy to .env.local for local development. Never commit secrets.

# Data source: mock (default) or odoo
CONTROL_CENTER_DATA_SOURCE=mock

# Odoo read-only API base URL (required when CONTROL_CENTER_DATA_SOURCE=odoo)
# Example: http://127.0.0.1:8094 or https://api-control-dev.raqeem.ma
RAQEEM_PLATFORM_API_BASE_URL=

# Optional bearer token — sent server-side only, never exposed to the browser
RAQEEM_PLATFORM_API_TOKEN=
